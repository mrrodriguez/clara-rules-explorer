# Load local-only environment variables if available
if [ -f .envrc.local ]; then
  source_env .envrc.local
fi

# Add local bin to PATH so scripts like clj-local are available
PATH_add bin

# Prefer Homebrew's GNU make if installed
if command -v brew &>/dev/null; then
  BREW_MAKE_PATH="$(brew --prefix)/opt/make/libexec/gnubin"
  if [ -d "$BREW_MAKE_PATH" ]; then
    PATH_add "$BREW_MAKE_PATH"
  else
    echo "Note: GNU make not found in Homebrew. You can install it using 'brew install make' to ensure GNU make is used."
  fi
fi
