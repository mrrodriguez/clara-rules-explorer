				"constraints": "[\n(= ?app-id app-id)\n\n(= doc-type :id-card)\n]"
			},
			"result-binding": "?docs"
		}
	],
	"retract-types": [],
	"notes": null,
	"annotation-sources": [],
	"insert-types": [],
	"rhs-form": "(do\n (r/insert!\n  (map->AllIdCardGivenDocuments {:app-id ?app-id, :docs ?docs})))\n",
