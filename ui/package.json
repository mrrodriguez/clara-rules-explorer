{
	"name": "ui",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.4.1",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check src static *.config.js *.config.ts package.json tsconfig.json && eslint src *.config.js *.config.ts",
		"format": "prettier --write src static *.config.js *.config.ts package.json tsconfig.json",
		"test:unit": "vitest --passWithNoTests",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test"
	},
	"dependencies": {
		"@popperjs/core": "^2.11.8",
		"bootstrap": "^5.3.8",
		"bootstrap-icons": "^1.13.1",
		"shiki": "^4.1.0"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/bootstrap": "^5.2.10",
		"@types/node": "^24.0.0",
		"@vitest/browser-playwright": "^4.1.3",
		"@vitest/ui": "^4.1.3",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"playwright": "^1.60.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"sass": "^1.99.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"vitest-browser-svelte": "^2.1.0"
	}
}
