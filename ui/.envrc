# 1. Automatic Node Version Switching (nvm/fnm)
# We attempt to trigger the user's Node manager if it's available.
if [ -f .nvmrc ]; then
  # FNM (Fast, binary-based)
  if command -v fnm >/dev/null 2>&1; then
    eval "$(fnm env --use-on-cd)"
    fnm use >/dev/null 2>&1
  # NVM (Shell function, needs to be sourced)
  elif [ -n "$NVM_DIR" ] && [ -f "$NVM_DIR/nvm.sh" ]; then
    . "$NVM_DIR/nvm.sh"
    nvm use >/dev/null 2>&1
  fi
fi

# 2. Local pnpm Setup
# We use a project-local directory for pnpm to ensure version 10.4.1 is used.
export PNPM_HOME="$PWD/.pnpm-home"
export PATH="$PNPM_HOME/bin:$PATH"

if ! command -v pnpm >/dev/null 2>&1; then
  if command -v npm >/dev/null 2>&1; then
    echo "📦 pnpm not found locally. Installing pnpm@10.4.1 into .pnpm-home..."
    npm install --quiet --no-progress pnpm@10.4.1 --global --prefix "$PNPM_HOME" >/dev/null 2>&1
  fi
fi

# 3. Validation
if command -v node >/dev/null 2>&1; then
  NODE_MAJOR=$(node -v | tr -d 'v' | cut -d. -f1)
  if [ "$NODE_MAJOR" -lt 24 ]; then
    echo "⚠️  Warning: Node 24+ is required. Found $(node -v)"
    echo "   Action: 'nvm use' or 'fnm use' to switch."
  fi
fi

if ! command -v pnpm >/dev/null 2>&1; then
  echo "❌ Error: pnpm installation failed."
fi

# Load local-only environment variables if available
if [ -f .envrc.local ]; then
  source_env .envrc.local
fi
