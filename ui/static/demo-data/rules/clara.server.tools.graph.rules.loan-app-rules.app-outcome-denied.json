{
	"downstream": [
		{
			"ns": "clara.server.tools.graph.rules.loan-app-rules",
			"name": "clara.server.tools.graph.rules.loan-app-rules/app-outcome-pending",
			"type": "rule"
		},
		{
			"ns": "clara.server.tools.graph.rules.loan-app-rules",
			"name": "clara.server.tools.graph.rules.loan-app-rules/find-app-outcome",
			"type": "query"
		}
	],
	"source-rule": false,
	"ns": "clara.server.tools.graph.rules.loan-app-rules",
	"name": "clara.server.tools.graph.rules.loan-app-rules/app-outcome-denied",
	"lhs-types": [
		"clara.server.tools.graph.rules.loan_app_facts.Application",
		"clara.server.tools.graph.rules.loan_app_rules.ApplicationOutcome",
		"clara.server.tools.graph.rules.loan_app_facts.DocumentCheck",
		"clara.server.tools.graph.rules.loan_app_facts.IdentityCheck",
		"clara.server.tools.graph.rules.loan_app_facts.FraudCheck"
	],
	"lhs": [
		{
			"type": "clara.server.tools.graph.rules.loan_app_facts.Application",
			"constraints": "[\n(= ?app-id app-id)\n]"
		},
		[
			"not",
			{
				"type": "clara.server.tools.graph.rules.loan_app_rules.ApplicationOutcome",
				"constraints": "[\n(= ?app-id app-id)\n\n(= status :approved)\n]"
			}
		],
		{
			"type": "clara.server.tools.graph.rules.loan_app_facts.DocumentCheck",
			"constraints": "[\n(= ?app-id app-id)\n\n(= ?doc-check-status status)\n]"
		},
		{
			"type": "clara.server.tools.graph.rules.loan_app_facts.IdentityCheck",
			"constraints": "[\n(= ?app-id app-id)\n\n(= ?identity-check-status status)\n]"
		},
		{
			"type": "clara.server.tools.graph.rules.loan_app_facts.FraudCheck",
			"constraints": "[\n(= ?app-id app-id)\n\n(= ?fraud-check-status status)\n]"
		}
	],
	"retract-types": [],
	"notes": null,
	"annotation-sources": ["clara-rules/insert-types"],
	"insert-types": ["clara.server.tools.graph.rules.loan_app_rules.ApplicationOutcome"],
	"rhs-form": "(do\n (let\n  [all-checks\n   [{:check-type :document, :status ?doc-check-status}\n    {:check-type :identity, :status ?identity-check-status}\n    {:check-type :fraud, :status ?fraud-check-status}]\n   passed-checks\n   (into\n    []\n    (comp (filter (comp #{:pass} :status)) (map :check-type))\n    all-checks)\n   failed-checks\n   (into\n    []\n    (comp (remove (comp #{:pass} :status)) (map :check-type))\n    all-checks)]\n  (r/insert!\n   (map->ApplicationOutcome\n    {:app-id ?app-id,\n     :status :denied,\n     :message \"Application denied\",\n     :passed-checks passed-checks,\n     :failed-checks failed-checks}))))\n",
	"upstream": [
		{
			"ns": "clara.server.tools.graph.rules.loan-app-rules",
			"name": "clara.server.tools.graph.rules.loan-app-rules/app-outcome-approved",
			"type": "rule"
		},
		{
			"ns": "clara.server.tools.graph.rules.loan-app-rules",
			"name": "clara.server.tools.graph.rules.loan-app-rules/app-outcome-pending",
			"type": "rule"
		},
		{
			"ns": "clara.server.tools.graph.rules.loan-doc-rules",
			"name": "clara.server.tools.graph.rules.loan-doc-rules/app-has-all-required-docs",
			"type": "rule"
		}
	],
	"doc": null,
	"sink-rule": false,
	"props": {
		"insert-types": ["clara.server.tools.graph.rules.loan_app_rules.ApplicationOutcome"]
	}
}
